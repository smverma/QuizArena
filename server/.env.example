# QuizArena Server – Environment Variables

# ── Optional ──────────────────────────────────────────────────────────────────

# Port the server listens on (Cloud Run sets PORT automatically to 8080)
PORT=3001

# GCP project ID.
# Recommended: always set this explicitly on Cloud Run so the app doesn't
# rely on ADC inference, which can point to the wrong project.
# Example: GCP_PROJECT_ID=quizarena-8279a
# GCP_PROJECT_ID=my-gcp-project

# Firestore database ID.
# This project uses a named Firestore database "quiz-free-tier".
# The code defaults to "quiz-free-tier" when this variable is not set.
# Override only if you created the Firestore database under a different ID
# (e.g. via: gcloud firestore databases create --database=mydb ...).
# Setting this to a database that does not exist causes a gRPC NOT_FOUND error
# and prevents Firestore from being reachable.
FIRESTORE_DATABASE_ID=quiz-free-tier

# Comma-separated list of allowed frontend origins for CORS.
# In production, set to your actual frontend URL.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Controls fail-fast behavior when Firestore is unreachable at startup.
# Default (unset / false): the server starts and listens on PORT even if
#   Firestore is misconfigured. Data routes return HTTP 503 until Firestore
#   becomes reachable. /health always returns 200 (Cloud Run friendly).
# Set to true: restores the original behavior – the process exits immediately
#   if the Firestore connectivity check fails.
# FAIL_FAST_ON_STARTUP=true

# When running the Firestore emulator locally, uncomment and set this:
# FIRESTORE_EMULATOR_HOST=localhost:8080
# Then start the emulator with: gcloud emulators firestore start --host-port=localhost:8080

# Path to a GCP service account JSON key (for local development without gcloud CLI).
# On Cloud Run this is NOT needed – ADC works automatically.
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account-key.json
