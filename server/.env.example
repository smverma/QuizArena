# QuizArena Server – Environment Variables

# ── Optional ──────────────────────────────────────────────────────────────────

# Port the server listens on (Cloud Run sets PORT automatically to 8080)
PORT=3001

# ── MySQL / Cloud SQL connection ──────────────────────────────────────────────
# Public IP of the Cloud SQL instance (europe-west1).
DB_HOST=34.22.246.245
DB_PORT=3306
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=quizarena

# Comma-separated list of allowed frontend origins for CORS.
# In production, set to your actual frontend URL.
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:4173

# Controls fail-fast behavior when the database is unreachable at startup.
# Default (unset / false): the server starts and listens on PORT even if
#   the DB is misconfigured. Data routes return HTTP 503 until the DB
#   becomes reachable. /health always returns 200 (Cloud Run friendly).
# Set to true: the process exits immediately if the DB connectivity check fails.
# FAIL_FAST_ON_STARTUP=true
